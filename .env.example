FTP_HOST=your_ftp_host
FTP_USER=your_ftp_user
FTP_PASSWORD=your_ftp_password
FTP_WEB_DIR=Web

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=your_database
MYSQL_USER=your_database_user
MYSQL_PASSWORD=your_database_password

APP_BASE_URL=http://gir.likeheng.com
APP_INGEST_TOKEN=change_me
APP_TRIGGER_TOKEN=change_me
APP_ADMIN_TOKEN=change_me

DEEPSEEK_API_KEY=change_me
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

GITHUB_TOKEN=change_me
GITHUB_OWNER=your_github_owner
GITHUB_REPO=your_repo_name

# 可选：指向一个本地的 CA 根证书 bundle 路径；设置后所有 PHP cURL 走严格证书校验。
# 可以放在 FTP 根目录的 Data/cacert.pem，或 Web/config/cacert.pem。
CA_BUNDLE_PATH=
